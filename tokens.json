      "semibold": { "value": 600, "type": "fontWeight", "description": "Reserved for marketing H1." }
    },
    "variant": {
      "numeric": { "value": "tabular-nums slashed-zero", "type": "fontVariantNumeric", "description": "Applied globally to numeric cells, chart axes, table values, solver logs." }
    },
