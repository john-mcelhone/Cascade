      "tight": { "value": "-0.01em", "type": "letterSpacing", "description": "Display sizes (>= xl)." },
      "default": { "value": "0", "type": "letterSpacing" },
      "wide": { "value": "0.04em", "type": "letterSpacing", "description": "All-caps tag chips." }
    }
  },

  "space": {
    "1": { "value": "4px", "type": "dimension", "description": "Inline icon-label gap, chip internal." },
    "2": { "value": "8px", "type": "dimension", "description": "Small-button padding, row internal." },
    "3": { "value": "12px", "type": "dimension", "description": "Compact panel padding, dense form gap." },
    "4": { "value": "16px", "type": "dimension", "description": "Default panel padding." },
    "5": { "value": "24px", "type": "dimension", "description": "Section gutter." },
    "6": { "value": "32px", "type": "dimension", "description": "Page top margin, between-card gap." },
    "7": { "value": "48px", "type": "dimension", "description": "Major section separation (marketing)." },
    "8": { "value": "64px", "type": "dimension", "description": "Hero-band vertical (marketing)." }
  },

  "radius": {
    "none": { "value": "0", "type": "dimension", "description": "Chart axes, plot frames, table cells." },
    "sm": { "value": "4px", "type": "dimension", "description": "Default for inputs, buttons, panels, tags." },
    "md": { "value": "6px", "type": "dimension", "description": "Cards, popovers, modals." },
    "lg": { "value": "10px", "type": "dimension", "description": "Marketing feature cards." },
    "full": { "value": "9999px", "type": "dimension", "description": "Avatars, status dots." }
  },

  "shadow": {
    "z1": {
      "light": { "value": "0 1px 2px rgba(14, 15, 18, 0.06)", "type": "shadow", "description": "Subtle hover lift; raised button." },
      "dark": { "value": "0 1px 2px rgba(0, 0, 0, 0.4)", "type": "shadow" }
    },
    "z2": {
      "light": { "value": "0 4px 8px rgba(14, 15, 18, 0.08), 0 1px 2px rgba(14, 15, 18, 0.04)", "type": "shadow", "description": "Dropdowns, popovers, tooltips." },
      "dark": { "value": "0 4px 8px rgba(0, 0, 0, 0.5)", "type": "shadow" }
    },
    "z3": {
      "light": { "value": "0 12px 24px rgba(14, 15, 18, 0.12), 0 2px 4px rgba(14, 15, 18, 0.08)", "type": "shadow", "description": "Modals, command palette." },
      "dark": { "value": "0 12px 24px rgba(0, 0, 0, 0.7)", "type": "shadow" }
    }
  },

  "motion": {
    "duration": {
      "fast": { "value": "100ms", "type": "duration", "description": "Hover states, focus rings." },
      "base": { "value": "150ms", "type": "duration", "description": "Default UI transitions." },
      "medium": { "value": "200ms", "type": "duration", "description": "Modal open, sidebar collapse." },
      "snap": { "value": "50ms", "type": "duration", "description": "Drag handles, scrubbing." },
      "exit": { "value": "120ms", "type": "duration", "description": "Modal close, toast dismiss (exits faster than entrances)." }
    },
    "easing": {
      "out": { "value": "cubic-bezier(0.4, 0, 0.2, 1)", "type": "cubicBezier", "description": "Default ease-out for UI transitions." },
      "in": { "value": "cubic-bezier(0.4, 0, 1, 1)", "type": "cubicBezier", "description": "Ease-in for element exits." },
      "linear": { "value": "linear", "type": "cubicBezier", "description": "Used only for drag/scrub motion.snap." }
    }
  },

  "icon": {
    "size": {
      "sm": { "value": "16px", "type": "dimension" },
      "base": { "value": "20px", "type": "dimension" },
      "lg": { "value": "24px", "type": "dimension", "description": "Default standalone size." },
      "xl": { "value": "32px", "type": "dimension", "description": "Empty-state hero only." }
    },
    "stroke": { "value": "1.5px", "type": "dimension", "description": "Lucide-family stroke width." },
    "grid": { "value": "4px", "type": "dimension", "description": "All icons aligned to a 4 px sub-grid." }
