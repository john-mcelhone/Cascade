{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Cascade design tokens. Semantic names only. Light and dark mode variants where applicable.",
  "$version": "0.1.0",

  "color": {
    "background": {
      "app": {
        "light": { "value": "#FFFFFF", "type": "color", "description": "Default app background, light mode." },
        "dark": { "value": "#1A1C21", "type": "color", "description": "Default app background, dark mode." }
      },
      "subtle": {
        "light": { "value": "#F7F7F8", "type": "color", "description": "Subtle background fill: zebra rows, faint section bands." },
        "dark": { "value": "#2C3038", "type": "color" }
      },
      "raised": {
        "light": { "value": "#FFFFFF", "type": "color", "description": "Cards and panels that sit above the app background." },
        "dark": { "value": "#4A4F58", "type": "color" }
      }
    },

    "surface": {
      "default": {
        "light": { "value": "#FFFFFF", "type": "color" },
        "dark": { "value": "#2C3038", "type": "color" }
      },
      "subtle": {
        "light": { "value": "#EEEFF1", "type": "color" },
        "dark": { "value": "#1A1C21", "type": "color" }
      },
      "input": {
        "light": { "value": "#FFFCEB", "type": "color", "description": "User-editable parameter cell tint (the yellow input convention, accessible)." },
        "dark": { "value": "#3A3318", "type": "color" }
      },
      "computed": {
        "light": { "value": "#F7F7F8", "type": "color", "description": "Solver-computed read-only cell tint." },
        "dark": { "value": "#2C3038", "type": "color" }
      }
