      "focus": {
        "light": { "value": "#2D6E78", "type": "color", "description": "Brand teal focus ring." },
        "dark": { "value": "#3F8B96", "type": "color" }
      }
    },

    "brand": {
      "default": {
        "light": { "value": "#2D6E78", "type": "color", "description": "Cascade teal." },
        "dark": { "value": "#3F8B96", "type": "color" }
