  "a11y": {
    "contrast": {
      "bodyText": { "value": "AAA", "type": "contrastTarget", "description": "WCAG AAA for normal text in both light and dark modes." },
      "largeText": { "value": "AAA", "type": "contrastTarget" },
      "uiControls": { "value": "AA", "type": "contrastTarget" }
    },
