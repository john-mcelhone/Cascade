      "sans": { "value": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", "type": "fontFamily", "description": "UI default. Inter variable; self-hosted." },
      "mono": { "value": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace", "type": "fontFamily", "description": "Numeric cells, solver logs, code blocks." },
      "display": { "value": "'Inter Display', Inter, sans-serif", "type": "fontFamily", "description": "Marketing-site H1 (Inter's Display optical-size axis)." }
    },
    "size": {
      "xs": { "value": "11px", "type": "dimension", "description": "Parameter cell values, status bar, tooltip footer." },
      "sm": { "value": "12px", "type": "dimension" },
      "base": { "value": "14px", "type": "dimension", "description": "Default product body text." },
      "md": { "value": "16px", "type": "dimension", "description": "Marketing & docs body." },
      "lg": { "value": "20px", "type": "dimension" },
      "xl": { "value": "28px", "type": "dimension" },
      "2xl": { "value": "40px", "type": "dimension", "description": "Homepage hero only." }
    },
    "lineHeight": {
      "xs": { "value": "16px", "type": "dimension" },
      "sm": { "value": "18px", "type": "dimension" },
      "base": { "value": "20px", "type": "dimension" },
      "md": { "value": "24px", "type": "dimension" },
      "lg": { "value": "28px", "type": "dimension" },
      "xl": { "value": "36px", "type": "dimension" },
      "2xl": { "value": "48px", "type": "dimension" }
