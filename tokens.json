        "2": { "value": "#C25B1F", "type": "color", "description": "sienna" },
        "3": { "value": "#2E8754", "type": "color", "description": "emerald" },
        "4": { "value": "#7A3DA8", "type": "color", "description": "violet" },
        "5": { "value": "#B47100", "type": "color", "description": "amber" },
        "6": { "value": "#1B9E9C", "type": "color", "description": "cerulean" },
        "7": { "value": "#C0407E", "type": "color", "description": "rose" },
        "8": { "value": "#4F5C66", "type": "color", "description": "slate" },
