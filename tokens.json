          "light": { "value": "#B5342E", "type": "color", "description": "Failed solver / failed validation / destructive action." },
          "dark": { "value": "#D14A45", "type": "color" }
        },
        "surface": {
          "light": { "value": "#F8E5E4", "type": "color" },
          "dark": { "value": "#3D1A19", "type": "color" }
        },
        "border": {
          "light": { "value": "#D27871", "type": "color" },
          "dark": { "value": "#7E2823", "type": "color" }
