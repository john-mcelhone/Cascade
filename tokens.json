      "muted": {
        "light": { "value": "#7A808A", "type": "color", "description": "De-emphasized text: secondary labels, units." },
        "dark": { "value": "#C1C5CB", "type": "color" }
      },
      "subtle": {
        "light": { "value": "#4A4F58", "type": "color" },
        "dark": { "value": "#DCDEE2", "type": "color" }
      },
      "disabled": {
        "light": { "value": "#C1C5CB", "type": "color" },
        "dark": { "value": "#7A808A", "type": "color" }
      },
      "inverse": {
        "light": { "value": "#FFFFFF", "type": "color", "description": "Text drawn on a dark surface in light mode (e.g. primary button label)." },
        "dark": { "value": "#1A1C21", "type": "color" }
      },
      "bound": {
        "light": { "value": "#7A3DA8", "type": "color", "description": "Italic chip color for parameters driven by a script binding (replaces a legacy red-italic convention)." },
        "dark": { "value": "#C7A6E5", "type": "color" }
