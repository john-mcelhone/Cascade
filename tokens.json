      "warning": {
        "default": {
          "light": { "value": "#B47100", "type": "color", "description": "Edge of recommended range / deprecation / regime edge." },
          "dark": { "value": "#D58F1F", "type": "color" }
        },
        "surface": {
          "light": { "value": "#FBF1DE", "type": "color" },
          "dark": { "value": "#3C2E0F", "type": "color" }
        },
        "border": {
          "light": { "value": "#D5A55B", "type": "color" },
          "dark": { "value": "#7A5E1F", "type": "color" }
        },
        "text": {
          "light": { "value": "#7C4F00", "type": "color" },
          "dark": { "value": "#F0CC85", "type": "color" }
